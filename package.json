{
  "name": "pdf2pdfa",
  "version": "1.0.0",
  "description": "A simple tool to convert PDF files to PDF/A files",
  "main": "app.js",
  "scripts": {
    "start": "export DEBUG='pdf2pdfA' && node bin/www.js",
    "dev": "export DEBUG='pdf2pdfA' && nodemon -e js,mjs,cjs,json,ejs bin/www.js",
    "test": "node --experimental-vm-modules ./node_modules/.bin/jest"
  },
  "keywords": [
    "pdf",
    "pdfa",
    "pdf2pdfa"
  ],
  "type": "module",
  "author": "jaideraf <jaideraf@gmail.com>",
  "license": "AGPL-3.0",
  "devDependencies": {
    "@types/compression": "^1.7.5",
    "@types/multer": "^1.4.12",
    "@types/serve-favicon": "^2.5.7",
    "eslint": "^10.0.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "jest": "^30.2.0",
    "nodemon": "^3.1.11",
    "prettier": "^3.8.1",
    "prettier-eslint-cli": "^8.0.1"
  },
  "dependencies": {
    "@jest/globals": "^30.2.0",
    "compression": "^1.7.5",
    "debug": "^4.4.0",
    "ejs": "^4.0.1",
    "express": "^4.21.2",
    "file-type": "^20.0.0",
    "helmet": "^8.0.0",
    "multer": "^2.0.2",
    "serve-favicon": "^2.5.0"
  },
  "bin": {
    "pdf2pdfa": "bin/www.js"
  }
}
